{
  "id": "app.offprint.block.text",
  "defs": {
    "main": {
      "type": "object",
      "required": [
        "plaintext"
      ],
      "properties": {
        "facets": {
          "type": "array",
          "items": {
            "ref": "app.offprint.richtext.facet",
            "type": "ref"
          },
          "description": "Facets for text formatting"
        },
        "plaintext": {
          "type": "string",
          "description": "The plain text content"
        },
        "textAlign": {
          "enum": [
            "left",
            "center",
            "right",
            "justify"
          ],
          "type": "string",
          "description": "Text alignment"
        }
      }
    }
  },
  "$type": "com.atproto.lexicon.schema",
  "lexicon": 1
}
