{
  "id": "app.offprint.block.orderedList",
  "defs": {
    "main": {
      "type": "object",
      "required": [
        "children"
      ],
      "properties": {
        "start": {
          "type": "integer",
          "default": 1,
          "description": "Starting number for the list"
        },
        "children": {
          "type": "array",
          "items": {
            "ref": "#listItem",
            "type": "ref"
          },
          "description": "List items"
        }
      }
    },
    "listItem": {
      "type": "object",
      "required": [
        "content"
      ],
      "properties": {
        "content": {
          "ref": "app.offprint.block.text",
          "type": "ref",
          "description": "Text content of the list item"
        },
        "children": {
          "type": "array",
          "items": {
            "ref": "#listItem",
            "type": "ref"
          },
          "description": "Nested list items"
        }
      }
    }
  },
  "$type": "com.atproto.lexicon.schema",
  "lexicon": 1
}
