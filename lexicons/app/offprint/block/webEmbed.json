{
  "id": "app.offprint.block.webEmbed",
  "defs": {
    "main": {
      "type": "object",
      "required": [
        "href"
      ],
      "properties": {
        "href": {
          "type": "string",
          "format": "uri",
          "required": true,
          "description": "The URL of the embedded page"
        },
        "title": {
          "type": "string",
          "description": "Page title",
          "maxGraphemes": 300
        },
        "width": {
          "type": "string",
          "description": "CSS width value (e.g., \"100%\", \"75%\". \"50%\" minimum)"
        },
        "preview": {
          "type": "blob",
          "accept": [
            "image/*"
          ],
          "maxSize": 1000000,
          "description": "Screenshot of the embedded content (1280\u00d7720px)"
        },
        "embedUrl": {
          "type": "string",
          "format": "uri",
          "description": "oEmbed URL for iframe embedding"
        },
        "siteName": {
          "type": "string",
          "description": "Name of the website",
          "maxGraphemes": 100
        },
        "alignment": {
          "enum": [
            "left",
            "center",
            "right"
          ],
          "type": "string",
          "description": "Horizontal alignment"
        },
        "embedWidth": {
          "type": "integer",
          "minimum": 1,
          "description": "Native embed width in pixels"
        },
        "description": {
          "type": "string",
          "description": "Page description/excerpt",
          "maxGraphemes": 1000
        },
        "embedHeight": {
          "type": "integer",
          "minimum": 1,
          "description": "Native embed height in pixels"
        }
      }
    }
  },
  "$type": "com.atproto.lexicon.schema",
  "lexicon": 1
}
