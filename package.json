{
  "name": "standard.horse",
  "version": "1.0.0",
  "description": "editor for standard.site",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lex:install": "lex install site.standard.publication site.standard.document",
    "lex:build": "lex build --index-file --override",
    "gen:og": "node scripts/gen-og.mjs",
    "postinstall": "lex build --index-file --override",
    "prebuild": "lex build --index-file --override",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "keywords": [],
  "author": "Samuel Newman <mozzius@protonmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@11.4.0+sha512.f0febc7e37552ab485494a914241b338e0b3580b93d54ce31f00933015880863129038a1b4ae4e414a0ee63ac35bf21197e990172c4a68256450b5636310968f",
  "dependencies": {
    "@atproto/lex": "^0.1.3",
    "@atproto/oauth-client-browser": "^0.4.1",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@plausible-analytics/tracker": "^0.4.5",
    "@uiw/react-codemirror": "^4.25.10",
    "react": "^19.2.6",
    "react-colorful": "^5.7.0",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-router": "^7.15.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "strip-markdown": "^6.0.0"
  },
  "devDependencies": {
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/newsreader": "^5.2.10",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "prettier": "^3.8.3",
    "satori": "^0.26.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  }
